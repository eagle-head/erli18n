%% Elvis style checker configuration.
%% Reference: https://github.com/inaka/elvis_core
%%
%% Philosophy: catch style drift that erlfmt + dialyzer + eqwalizer don't
%% cover. Keep the rule set small and high-signal; an overly noisy linter
%% gets ignored.
%%
%% We do NOT use `ruleset => erl_files` here — that pulls in defaults
%% (god_modules, max_function_length, no_throw) that fight legitimate
%% patterns in this codebase. We list every active rule explicitly.
%%
%% Rules NOT enforced (with rationale):
%%   * god_modules         — the public façade (`erli18n.erl`) is
%%     intentionally large (12 GNU C-macro operations × 2-3 arities + aliases).
%%   * max_function_length — `cldr_data/0` is a literal lookup table (49
%%     locales); splitting would obscure intent.
%%   * no_throw            — `erli18n_plural`/`erli18n_po` use `throw/1`
%%     for short-circuit error propagation in recursive descent parsers.
%%     Caught at the public-API boundary and translated to `{error, _}`.
%%     Standard parser pattern.
%%   * dont_repeat_yourself — false positives in lookup tables and test
%%     setup boilerplate.
[
    {elvis, [
        {config, [
            %% Production source — every umbrella app's `src/` plus the
            %% downstream consumer example (which lives under `examples/`,
            %% outside the `apps/*` discovery root, but is production-shaped
            %% Erlang we hold to the same style bar).
            #{
                dirs => ["apps/*/src", "examples/erli18n_demo/src"],
                filter => "*.erl",
                rules => [
                    {elvis_text_style, line_length, #{limit => 100, skip_comments => false}},
                    {elvis_text_style, no_tabs},
                    {elvis_text_style, no_trailing_whitespace},
                    {elvis_style, macro_names, #{regex => "^([A-Z][A-Z_0-9]+)$"}},
                    {elvis_style, operator_spaces, #{rules => [{right, ","}, {right, "++"}, {left, "++"}]}},
                    {elvis_style, no_debug_call, #{debug_functions => [{ct, pal}, {ct, print}, {io, format, 1}]}},
                    {elvis_style, no_common_caveats_call},
                    {elvis_style, no_catch_expressions},
                    {elvis_style, used_ignored_variable},
                    {elvis_style, no_behavior_info},
                    {elvis_style, module_naming_convention, #{regex => "^[a-z][a-z0-9_]*$"}},
                    {elvis_style, function_naming_convention, #{regex => "^[a-z][a-z0-9_]*$"}},
                    {elvis_style, variable_naming_convention, #{regex => "^_?[A-Z][0-9a-zA-Z_]*$"}},
                    {elvis_style, no_spec_with_records},
                    {elvis_style, no_call, #{no_call_functions => [{erlang, halt, 1}, {erlang, halt, 2}, {init, stop, 0}]}}
                ]
            },

            %% The umbrella root `rebar.config`, every app's `rebar.config`,
            %% and the downstream consumer example's `rebar.config`.
            #{
                dirs => [".", "apps/*", "examples/erli18n_demo"],
                filter => "rebar.config",
                rules => [
                    {elvis_text_style, line_length, #{limit => 100}},
                    {elvis_text_style, no_tabs},
                    {elvis_text_style, no_trailing_whitespace}
                ]
            },

            %% Tests — relaxed rules. Common Test conventions require
            %% module names ending in `_SUITE` (uppercase suffix) and
            %% atoms with numbers like `gettext_3_explicit_locale`.
            #{
                dirs => ["apps/*/test"],
                filter => "*.erl",
                rules => [
                    {elvis_text_style, line_length, #{limit => 120}},
                    {elvis_text_style, no_tabs},
                    {elvis_text_style, no_trailing_whitespace},
                    {elvis_style, macro_names, #{regex => "^([A-Z][A-Z_0-9]+)$"}},
                    {elvis_style, module_naming_convention, #{regex => "^[a-z][a-z0-9_]*(_SUITE)?$"}},
                    {elvis_style, function_naming_convention, #{regex => "^[a-z][a-z0-9_]*$"}},
                    {elvis_style, no_catch_expressions},
                    {elvis_style, used_ignored_variable},
                    {elvis_style, variable_naming_convention, #{regex => "^_?[A-Z][0-9a-zA-Z_]*$"}}
                ]
            }
        ]}
    ]}
].
