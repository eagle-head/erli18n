# EditorConfig — https://editorconfig.org
# Universal indentation and whitespace conventions, applied by any
# editor with EditorConfig support. Project-specific formatting is
# handled by `erlfmt` (Erlang) and the workflow YAML conventions.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Erlang sources: erlfmt's default style is 4-space indent, 100-col line
# width. The .editorconfig values must agree so editors and erlfmt do
# not fight each other.
[*.{erl,hrl}]
indent_style = space
indent_size = 4
max_line_length = 100

# Rebar and Elvis config files are Erlang terms.
[{rebar.config,rebar.lock,elvis.config,*.app.src}]
indent_style = space
indent_size = 4

# `.po` / `.pot` translation files: GNU gettext convention is no indent
# (msgid/msgstr keys are flush-left). Trailing whitespace inside quoted
# strings is significant — keep it.
[*.{po,pot}]
indent_style = space
indent_size = 4
trim_trailing_whitespace = false

# YAML (GitHub Actions, Docker Compose): 2-space indent is the
# overwhelming convention; mixing tabs breaks parsers.
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Dockerfile, shell scripts, Markdown: standard conventions.
[Dockerfile*]
indent_style = space
indent_size = 4

[*.{sh,bash}]
indent_style = space
indent_size = 4

[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false
