%% erli18n_elli_demo — a standalone, runnable example of the optional
%% `erli18n_elli` middleware (per-request locale negotiation for Elli).
%%
%% Like `examples/erli18n_demo`, this app lives OUTSIDE the umbrella's `apps/*`
%% root, so it is a SEPARATE rebar3 project that consumes `erli18n` exactly as a
%% real downstream app would. Because `erli18n` 0.7.0 is not yet published to
%% Hex, the unpublished in-repo library is surfaced through rebar3's documented
%% `_checkouts/` override (gitignored):
%%
%%   examples/erli18n_elli_demo/_checkouts/erli18n -> ../../../apps/erli18n
%%
%% Create it once with (see README.md):
%%   ln -s ../../../apps/erli18n examples/erli18n_elli_demo/_checkouts/erli18n
%%
%% `elli` is pinned from git at tag 3.3.0 — the exact version the erli18n
%% adapters are built and tested against (it matches the umbrella's test-profile
%% pin), so this example is reproducible. A real downstream app typically uses
%% the Hex package instead (`{elli, "~> 3.3"}`). The `~> 0.7` erli18n constraint
%% is satisfied by the `_checkouts/erli18n` checkout (vsn 0.7.0).

{erl_opts, [
    debug_info,
    warnings_as_errors,
    warn_unused_vars,
    warn_shadow_vars,
    warn_obsolete_guard
]}.

{deps, [
    {erli18n, "~> 0.7"},
    {elli, {git, "https://github.com/elli-lib/elli.git", {tag, "3.3.0"}}}
]}.

{shell, [{apps, [erli18n_elli_demo]}]}.
