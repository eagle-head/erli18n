%% erli18n_cowboy_demo — a standalone, runnable example of the optional
%% `erli18n_cowboy` middleware (per-request locale negotiation for Cowboy).
%%
%% Like `examples/erli18n_demo`, this app lives OUTSIDE the umbrella's `apps/*`
%% root, so it is a SEPARATE rebar3 project that consumes `erli18n` exactly as a
%% real downstream app would. Because `erli18n` 0.6.0 is not yet published to
%% Hex, the unpublished in-repo library is surfaced through rebar3's documented
%% `_checkouts/` override (gitignored):
%%
%%   examples/erli18n_cowboy_demo/_checkouts/erli18n -> ../../../apps/erli18n
%%
%% Create it once with (see README.md):
%%   ln -s ../../../apps/erli18n examples/erli18n_cowboy_demo/_checkouts/erli18n
%%
%% `cowboy` is pinned from git at tag 2.13.0 — the exact version the erli18n
%% adapters are built and tested against (it matches the umbrella's test-profile
%% pin), so this example is reproducible and resolves `cowlib` / `ranch` through
%% cowboy's own rebar.config. A real downstream app typically uses the Hex
%% package instead (`{cowboy, "~> 2.13"}`, the constraint the erli18n README
%% recommends) once its rebar3 resolves cowboy's `cowlib` requirement cleanly.
%% The `~> 0.6` erli18n constraint is satisfied by the `_checkouts/erli18n`
%% checkout (vsn 0.6.0).

{erl_opts, [
    debug_info,
    warnings_as_errors,
    warn_unused_vars,
    warn_shadow_vars,
    warn_obsolete_guard
]}.

{deps, [
    {erli18n, "~> 0.6"},
    {cowboy, {git, "https://github.com/ninenines/cowboy.git", {tag, "2.13.0"}}}
]}.

{shell, [{apps, [erli18n_cowboy_demo]}]}.
