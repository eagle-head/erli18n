%% erli18n_demo — the real downstream consumer of the erli18n library AND the
%% rebar3_erli18n catalog plugin.
%%
%% This app lives under `examples/` (deliberately NOT under `apps/`) so the
%% umbrella's `apps/*` discovery root does NOT pick it up: it is a SEPARATE
%% rebar3 project that consumes the two umbrella packages exactly as a real
%% downstream project would. It is what proves the plugin -> lib consumption
%% end to end and is the home of the non-vacuous `rebar3 erli18n check` gate.
%%
%% Because neither `erli18n` nor `rebar3_erli18n` is published to Hex yet, and
%% rebar3 has NO native `{path, ...}` dependency resource (that needs the
%% third-party `rebar3_path_deps` plugin), this consumer surfaces BOTH in-repo
%% apps through rebar3's documented `_checkouts/` override:
%%
%%   examples/erli18n_demo/_checkouts/erli18n        -> ../../../apps/erli18n
%%   examples/erli18n_demo/_checkouts/rebar3_erli18n -> ../../../apps/rebar3_erli18n
%%
%% Both the `{deps, [...]}`/`{plugins, [...]}` entries below (by name) AND the
%% two `_checkouts` links are load-bearing (verified against rebar3 3.24 /
%% OTP 28): the named entries are what rebar3 resolves, and the checkouts take
%% precedence over a Hex fetch for those names so the unpublished in-repo apps
%% are used instead. See `apps/rebar3_erli18n/README.md` ("Local development —
%% the two-checkouts requirement"). After both packages publish, this consumer
%% drops the checkouts and resolves both from Hex unchanged.

{erl_opts, [
    debug_info,
    warnings_as_errors,
    warn_unused_vars,
    warn_shadow_vars,
    warn_obsolete_guard
]}.

%% `erli18n` is the runtime dependency: this app's modules call
%% `erli18n:gettext/1` and friends. The `~> 0.7` constraint matches the
%% `_checkouts/erli18n` checkout (vsn 0.7.0) and the canonical constraint the
%% sibling demos (cowboy / elli) pin. `telemetry` is
%% pulled transitively
%% by `erli18n` from Hex.
{deps, [
    {erli18n, "~> 0.7"}
]}.

%% Opt in to the catalog tooling. The bare `rebar3_erli18n` name must be present
%% so the `_checkouts/rebar3_erli18n` checkout can take precedence over a Hex
%% fetch for it; the plugin's own `{deps, [{erli18n, ...}]}` is what binds the
%% consumer's `_checkouts/erli18n` onto the plugin's code path at provider-run
%% time.
{plugins, [
    rebar3_erli18n
]}.

{shell, [{apps, [erli18n_demo]}]}.
