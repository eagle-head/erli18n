%% Umbrella root config.
%%
%% This repo is a rebar3 umbrella. The runtime library lives in
%% `apps/erli18n/` (published to Hex as the `erli18n` package). Its runtime
%% dependency set (`telemetry`), compile options, and shell config live in
%% `apps/erli18n/rebar.config` so the published package is self-contained.
%%
%% This root file carries only umbrella-wide settings: the dev/test plugins
%% and `test` profile deps, and the dialyzer/xref/hank/erlfmt policy applied
%% across every app. Each published app owns its own publishing config: its
%% `{deps,...}`, its `{ex_doc,...}`/`{hex,...}` doc config, AND its own
%% `{project_plugins, [rebar3_hex, rebar3_ex_doc]}`, because each package is
%% built and published from its OWN app directory (`cd apps/<app> && rebar3 hex
%% publish ...`) — see `apps/erli18n/rebar.config`,
%% `apps/rebar3_erli18n/rebar.config`, and `.github/workflows/release.yml`. The
%% `rebar3_hex`/`rebar3_ex_doc` entries in THIS root `{project_plugins,...}`
%% below are for the umbrella-level dev convenience commands; the per-app copies
%% are what the per-app publish path actually uses.

%% Shared compile options applied to every app in the umbrella. Each app's
%% own `rebar.config` re-states the runtime-relevant subset it needs; this
%% root copy keeps `rebar3 compile` at the umbrella level warning-clean.
{erl_opts, [
    debug_info,
    warnings_as_errors,
    warn_unused_vars,
    warn_shadow_vars,
    warn_obsolete_guard
]}.

{minimum_otp_vsn, "27"}.

%% Quality-gate plugins. Invoked via `bin/quality-gate.sh` (manual or git
%% hooks). Each plugin is build-only — no runtime impact on the lib.
%%
%%   * `erlfmt`        — canonical formatter (WhatsApp/Meta; Apache-2.0).
%%   * `rebar3_hank`   — dead code detector (AdRoll; Apache-2.0).
%%   * `rebar3_lint`   — Elvis style checker (Inaka; Apache-2.0).
%%   * `rebar3_ex_doc` — generates HexDocs-style HTML from the native
%%     `-doc` attributes (Erlang/OTP 27+). Provided here for umbrella-level dev
%%     convenience; actual doc rendering for a package is driven by
%%     `scripts/gen_docs.sh <app>` (which routes around the EDoc-chunk bug), and
%%     publishing happens per-app — see below.
%%   * `rebar3_hex`    — Hex.pm packaging/publishing. Provided here for ad-hoc
%%     umbrella-level inspection (e.g. `rebar3 hex build --app <app>`), but the
%%     RELEASE path publishes each package from its OWN app directory
%%     (`cd apps/<app> && rebar3 hex publish ...`), using that app's own
%%     `{project_plugins, [rebar3_hex, rebar3_ex_doc]}`. Publishing per-app (not
%%     `--app` from this root) is what makes a package's sibling-app dependency
%%     land in its published Hex `requirements`; see
%%     `apps/rebar3_erli18n/rebar.config` and `.github/workflows/release.yml`.
%%
%% Note on eqWAlizer (Meta's gradual type checker): it is NOT a rebar3
%% plugin. It runs via the `elp` CLI (Erlang Language Platform). The
%% quality-gate script invokes `elp eqwalize-all` and `elp lint`. In the
%% `--full`/`--pre-push` lane elp is a HARD requirement: a `require_elp` step
%% records a real FAIL (non-zero gate exit) when elp is absent, so the type
%% gate can never silently SKIP-to-green; only the cheap `--fast` lane
%% soft-skips elp with a hint. See
%% https://whatsapp.github.io/eqwalizer/getting-started/ for elp install.
{project_plugins, [
    {erlfmt, "~> 1.5"},
    {rebar3_hank, "~> 1.4"},
    {rebar3_lint, "~> 3.2"},
    {rebar3_hex, "~> 7.0"},
    {rebar3_ex_doc, "~> 0.2"}
]}.

%% erlfmt scope. The plugin is invoked with `--check` (CI) or `--write`
%% (auto-fix) from the quality-gate script. Covers the umbrella root
%% `rebar.config` plus every app's sources and its own `rebar.config`, and the
%% `examples/erli18n_demo/` downstream consumer (which lives OUTSIDE `apps/` so
%% the umbrella does not auto-discover it, but is still ours to keep formatted).
{erlfmt, [
    {files, [
        "apps/*/{src,test}/*.{erl,app.src}",
        "apps/*/rebar.config",
        "examples/erli18n_demo/src/*.{erl,app.src}",
        "examples/erli18n_demo/rebar.config",
        "rebar.config"
    ]}
]}.

%% Test-only deps: PropEr (property/fuzz harness) and `eqwalizer_support`
%% (the eqwalizer toolchain anchor — see the rationale below).
%%
%%   * PropEr (Apache-2.0; https://hexdocs.pm/proper/) is the canonical
%%     QuickCheck implementation for Erlang (Papadakis et al., PADL 2011
%%     https://proper-testing.github.io/papers/proper_acm.pdf). The
%%     `~> 1.4` constraint pins PropEr to >= 1.4; the latest stable
%%     line at the time of writing is 1.5.x.
%%
%%   * `eqwalizer_support` is the REQUIRED project dependency for running
%%     eqwalizer (Meta's gradual type checker) via the `elp` CLI — exactly the
%%     `git_subdir` form the official getting-started instructions prescribe
%%     (https://github.com/WhatsApp/eqwalizer#using-eqwalizer). It is the
%%     anchor `elp eqwalize-all` uses to resolve eqwalizer's OTP/stdlib type
%%     overlays; WITHOUT it, `elp eqwalize-all` cannot narrow stdlib results
%%     and reports `incompatible_types` against `term()` across every `src`
%%     module (a locally-reproduced 174-error degrade), so the dep is
%%     load-bearing for the type gate, not optional.
%%
%%     IMPORTANT — this dep is NO LONGER on the test suites' runtime code path.
%%     The PropEr-generator boundaries (where the statically-inferred type is
%%     `term()` by design) used to bind values via a RUNTIME
%%     `eqwalizer:dynamic_cast/1` call from `eqwalizer_support`. That call
%%     `undef`-crashed at CT run time because the `git_subdir` checkout lands
%%     the beam at a double-nested path (`.../eqwalizer_support/
%%     eqwalizer_support/ebin`) that rebar3's ct provider never adds to the
%%     code path. Those boundaries are now reconciled with a static
%%     `-eqwalizer({nowarn_function, F/A}).` annotation on each affected
%%     function — the same zero-runtime-dep pattern already used in the runtime
%%     modules `erli18n_server` and `erli18n_pt_store`. So `eqwalizer_support`
%%     is retained ONLY as the build-time eqwalizer toolchain dep (its
%%     double-nesting no longer matters, because nothing calls into it at
%%     run time), and the suites no longer fail with `{undef, dynamic_cast}`.
%%
%% The parity oracle is NOT a rebar dependency: `erli18n_parity_SUITE`
%% shells out to the real GNU gettext CLI (`msgfmt`, `gettext`,
%% `ngettext`) installed on the system, and skips its scenarios cleanly
%% when that toolchain — or the required UTF-8 locales — is absent.
{profiles, [
    {test, [
        {deps, [
            {proper, "~> 1.4"},
            {eqwalizer_support,
                {git_subdir, "https://github.com/whatsapp/eqwalizer.git", {branch, "main"},
                    "eqwalizer_support"}}
        ]}
    ]}
]}.

%% Dialyzer needs PLT entries for telemetry if it's available — adding it
%% to plt_extra_apps keeps `rebar3 dialyzer` warning-free when the dep is
%% present. The lib still compiles without it because every call site is
%% guarded by `erli18n_telemetry:emit/3,4` indirection.
{dialyzer, [
    {warnings, [unknown]},
    {plt_extra_apps, [telemetry]}
]}.

%% Xref: we drop `unused_exports` from the default set. erli18n is a
%% publishable library — every public function exists for external
%% consumers (or for test/property suites that xref doesn't scan), so
%% "unused export" inside the lib is the norm, not a defect. We keep
%% the checks that catch genuine bugs.
{xref_checks, [
    undefined_function_calls,
    undefined_functions,
    locals_not_used,
    deprecated_function_calls,
    deprecated_functions
]}.

%% Xref host-API resolution for the `rebar3_erli18n` plugin app, scoped to the
%% eight rebar3 host `{M, F, A}` edges.
%%
%% `apps/*` is rebar3's default discovery root, so the umbrella-level
%% `rebar3 xref` (what `bin/quality-gate.sh` runs, and what
%% `rebar_state:get(State, xref_ignores, [])` reads from THIS root config —
%% per-app `xref_ignores` are not consulted for a root run) scans the plugin.
%% The plugin's host seam `rebar3_erli18n_host` makes eight calls into modules
%% that live inside the rebar3 escript — `providers:create/1`,
%% `rebar_state:add_provider/2`, `rebar_state:command_parsed_args/1`,
%% `rebar_state:project_apps/1`, `rebar_state:dir/1`, `rebar_app_info:dir/1`,
%% `rebar_api:info/2`, `rebar_api:console/2`. Those modules are NOT a fetchable
%% Hex dep (there is no `rebar`/`rebar3` package carrying them), so xref reports
%% each as undefined. We ignore EXACTLY those eight edges and nothing else, so
%% `undefined_function_calls`/`undefined_functions` stay ACTIVE for genuine bugs
%% in every other module — including the plugin's own logic. The same eight
%% edges are mirrored in `apps/rebar3_erli18n/rebar.config` (consulted when the
%% plugin is analyzed standalone as a published package) and in an
%% `-ignore_xref([...])` attribute on the `rebar3_erli18n_host` seam. This
%% scoped ignore is the structural mechanism for the host seam (the plugin
%% receives these modules from the rebar3 escript at plugin-load time); it is
%% load-bearing (removing it makes exactly these eight calls reappear as
%% undefined) and not over-broad.
%%
%% Rejected alternatives (see apps/rebar3_erli18n/README.md):
%%   (a) declare rebar3 as a build dep — impossible, no `rebar`/`rebar3` Hex
%%       package exists;
%%   (c) exclude the whole plugin app from xref — over-broad; it would silence
%%       real undefined-call bugs in the plugin's own modules.
{xref_ignores, [
    {providers, create, 1},
    {rebar_state, add_provider, 2},
    {rebar_state, command_parsed_args, 1},
    {rebar_state, project_apps, 1},
    {rebar_state, dir, 1},
    {rebar_app_info, dir, 1},
    {rebar_api, info, 2},
    {rebar_api, console, 2}
]}.

%% Hank (dead code detector) — silence ONLY false positives, leaving the
%% real rules (`unused_includes`, `unused_macros`, `unused_record_fields`)
%% active for every other file. Hank flags a glob ignore as "no longer needed"
%% per matched file that has zero hits for the rule, so each glob below is
%% scoped to exactly the files that actually trigger its rule:
%%
%%   * `unnecessary_function_arguments` — CT callbacks must take a `Config`/`_`
%%     argument per the behaviour contract even when a particular test body
%%     ignores it. Every `erli18n` suite triggers this, so the lib glob is the
%%     full `*_SUITE.erl`. In the plugin only the six data-driven suites below
%%     trigger it; `extract_SUITE.erl` genuinely threads `Config` through every
%%     test (it reads the per-test `data_dir`), so it is deliberately EXCLUDED
%%     from the brace glob to keep the ignore non-vacuous.
%%   * `unused_macros` for `consumer_bad_macro.erl` — this extraction fixture
%%     defines `?GETTEXT_DOMAIN` to a NON-atom string on purpose; the value is
%%     consumed by the `rebar3 erli18n extract` macro reader from the fixture's
%%     abstract forms (asserting the reader falls back to `default`), not by
%%     the fixture module itself, so hank cannot see the use. Scoped to that
%%     one file.
%%   * `unused_macros` for `examples/erli18n_demo/src/erli18n_demo_errors.erl` —
%%     the SAME cross-tool use in production shape: the demo module defines
%%     `?GETTEXT_DOMAIN` to the literal atom `errors` to partition its strings
%%     into the `errors` domain. The macro is read by the `rebar3 erli18n
%%     extract` macro reader from the module's expanded abstract form (it
%%     decides which `.pot` the calls land in), not referenced textually in the
%%     module body, so hank reports it as unused. The macro is load-bearing
%%     (removing it moves every entry from `errors.pot` to `default.pot` and
%%     breaks the committed baseline), so the ignore is justified, not a
%%     workaround. Scoped to that one file.
{hank, [
    {ignore, [
        {"apps/erli18n/test/*_SUITE.erl", [unnecessary_function_arguments]},
        {"apps/rebar3_erli18n/test/{common,jaro,keywords,po_meta,providers,roundtrip}_SUITE.erl", [
            unnecessary_function_arguments
        ]},
        {"apps/rebar3_erli18n/test/extract_SUITE_data/consumer_bad_macro.erl", [unused_macros]},
        {"examples/erli18n_demo/src/erli18n_demo_errors.erl", [unused_macros]}
    ]}
]}.
