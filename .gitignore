.DS_Store

# Generated API documentation (scripts/gen_docs.sh -> ex_doc; published to HexDocs)
doc/

# Per-app rebar.lock files. Each package is published from its own directory
# (`cd apps/<app> && rebar3 hex publish ...`); that build resolves the package's
# deps from Hex and writes a transient `apps/<app>/rebar.lock` whose pinned
# versions reflect whatever was live on Hex at publish time. It is a publish-time
# artifact, not source — the umbrella's own dev/test lock is the tracked root
# `rebar.lock`. (The exemplar open-telemetry/opentelemetry-erlang likewise tracks
# only the root lock and no per-app locks.) The leading slash keeps the root
# `rebar.lock` tracked.
apps/*/rebar.lock

# Benchmark harness — archived on the experiment/persistent-term-benchmark branch
# only, never on main. This ignores leftover working-tree scratch from branch
# switches so it is never accidentally tracked here.
bench/

# The example apps surface the unpublished in-repo apps via rebar3's native
# `_checkouts/` override. Those symlinks (and each example's `_build/`) are
# recreatable build artifacts, not source — recreate them with:
#   ln -s ../../../apps/erli18n        examples/erli18n_demo/_checkouts/erli18n
#   ln -s ../../../apps/rebar3_erli18n examples/erli18n_demo/_checkouts/rebar3_erli18n
#   ln -s ../../../apps/erli18n        examples/erli18n_cowboy_demo/_checkouts/erli18n
#   ln -s ../../../apps/erli18n        examples/erli18n_elli_demo/_checkouts/erli18n
# The committed baseline `.pot`/`.po` under priv/gettext/ are NOT ignored: for
# erli18n_demo they are the reference the `rebar3 erli18n check` gate compares
# against; for the middleware examples they are the catalogs loaded at runtime.
examples/erli18n_demo/_checkouts/
examples/erli18n_demo/_build/
examples/erli18n_cowboy_demo/_checkouts/
examples/erli18n_cowboy_demo/_build/
examples/erli18n_elli_demo/_checkouts/
examples/erli18n_elli_demo/_build/

# Parity gate scratch: docker-compose.yml bind-mounts ./.gate/artifacts <->
# /artifacts, where the gettext-extract service drops the generated oracle
# (parity_oracle.eterm) and plural table (plural_forms.extracted.eterm). These
# are regenerated on every run, never source. The pattern is root-anchored
# (`/.gate/`) — a gitignore entry cannot begin with `./`, so the literal
# `./.gate/` would match nothing; `/.gate/` is the equivalent "relative to repo
# root" form that actually ignores the directory.
/.gate/
